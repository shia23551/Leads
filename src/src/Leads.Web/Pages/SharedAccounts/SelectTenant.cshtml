@page
@model Leads.Web.Pages.SharedAccounts.SelectTenantModel
@using Leads.Localization
@using Leads.Web.Menus
@using Microsoft.AspNetCore.Mvc.Localization
@using Volo.Abp.AspNetCore.Mvc.UI.Layout
@inject IPageLayout PageLayout
@inject IHtmlLocalizer<LeadsResource> L
@{
    PageLayout.Content.Title = L["SelectTenant"].Value;
    PageLayout.Content.MenuItemName = LeadsMenus.SharedAccountSelectTenant;
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white"><h5 class="mb-0">@L["SelectTenant"]</h5></div>
            <div class="card-body">
                @if (Model.Tenants.Count == 0)
                {
                    <div class="alert alert-warning mb-0">@L["NoTenantMembershipFound"]</div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var tenant in Model.Tenants)
                        {
                            <form method="post" asp-page-handler="Switch" class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-semibold">@tenant.Name</div>
                                    @if (tenant.IsCurrent)
                                    {
                                        <small class="text-muted">@L["CurrentTenant"]</small>
                                    }
                                </div>
                                <div>
                                    <input type="hidden" name="tenantId" value="@tenant.Id" />
                                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                                    <button type="submit" class="btn btn-sm btn-primary">@L["Switch"]</button>
                                </div>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
